# Copier vers .env et adapter les valeurs. Ne jamais committer .env.

# SQLite local (sans Docker) :
DATABASE_URL=sqlite:///./comptabilite.db

# Ou PostgreSQL (Docker local) :
# DATABASE_URL=postgresql://comptabilite:REMPLACER_MOT_DE_PASSE@localhost:5433/comptabilite

POSTGRES_USER=comptabilite
POSTGRES_PASSWORD=REMPLACER_PAR_UN_MOT_DE_PASSE_FORT
POSTGRES_DB=comptabilite

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_CLE=REMPLACER_PAR_UNE_CLE_LONGUE_ALEATOIRE
ENVIRONNEMENT=developpement

VITE_API_URL=http://localhost:8000
VITE_API_CLE=REMPLACER_PAR_UNE_CLE_LONGUE_ALEATOIRE
